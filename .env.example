# This file is read by DOCKER COMPOSE ITSELF for ${VARIABLE} substitution in
# docker-compose.prod.yml (e.g. the frontend build arg below) — it is NOT the
# same as backend/.env.production, which Laravel reads at container runtime.
# Both files need to exist and agree with each other. Copy this to `.env` in
# the project root before running `docker compose -f docker-compose.prod.yml build`.

VITE_API_URL=https://api.yourdomain.com/api/v1
