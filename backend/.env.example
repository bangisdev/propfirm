APP_NAME=PropFirm
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=propfirm
DB_USERNAME=propfirm
DB_PASSWORD=secret

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_SECURE_COOKIE=false

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@propfirm.io
MAIL_FROM_NAME="${APP_NAME}"

JWT_SECRET=
JWT_TTL=15
JWT_ALGO=HS256
JWT_BLACKLIST_ENABLED=true

CORS_ALLOWED_ORIGINS=http://localhost:5173

# Paystack (Phase 2)
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# MT5 bridge service (Phase 2)
MT5_BRIDGE_URL=http://mt5-bridge:9000
MT5_BRIDGE_API_KEY=
